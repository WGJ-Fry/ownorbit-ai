DEFINE SCHEMA

// OwnOrbit stores only reviewable, non-credential payloads in the private database.
// Public database grants are intentionally omitted.

RECORD TYPE LifeOSConversation (
    "___recordID" REFERENCE QUERYABLE,
    lifeosSchema STRING,
    lifeosDataType STRING,
    lifeosRecordType STRING,
    lifeosRecordName STRING,
    sourceIdHash STRING,
    mutationId STRING,
    logicalClock INT64,
    contentHash STRING,
    payloadJson STRING,
    payloadByteSize INT64,
    requiresUserReview INT64,
    lifeosSyncedAt TIMESTAMP,
    lifeosKind STRING,
    createdAt TIMESTAMP,
    expiresAt TIMESTAMP
);

