# Gemini API key used by the local OwnOrbit Core.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional. Manage the admin password through environment instead of first-run setup.
# LIFEOS_ADMIN_PASSWORD="change-this-long-password"

# Optional. Defaults to 3000 when available.
LIFEOS_PORT=3000

# Optional. Defaults to 127.0.0.1 for safer desktop-only access.
# Use 0.0.0.0 only when you need LAN/mobile access and have set an admin password.
LIFEOS_HOST=127.0.0.1

# Required when LIFEOS_HOST=0.0.0.0 or PUBLIC_BASE_URL is set.
# LIFEOS_ALLOW_PUBLIC=1

# Optional. Trust X-Forwarded-For for rate limiting only when behind a controlled reverse proxy.
# LIFEOS_TRUST_PROXY=1

# Optional. Device token lifetime in days before the mobile client must rotate/rebind.
LIFEOS_DEVICE_TOKEN_TTL_DAYS=30

# Optional. Number of SQLite backup files to keep. Use 0 to disable pruning.
LIFEOS_BACKUP_RETENTION_COUNT=20

# Optional. Public HTTPS origin used in mobile pairing QR codes.
# Example: https://lifeos-yourname.trycloudflare.com
# PUBLIC_BASE_URL=""

# Optional. Defaults to ./data in server mode and the app userData folder in desktop mode.
# LIFEOS_DATA_DIR="/absolute/path/to/lifeos-data"

# Optional. Display name used by the desktop local core.
LIFEOS_DEVICE_NAME="OwnOrbit Desktop"
